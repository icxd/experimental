import "std/mem.rye";

struct String {
  ptr *byte;
  len int;
}

proc is_empty(s String) bool {
  return s.len == 0;
}

proc eq(a String, b String) bool {
  if a.len != b.len {
    return false;
  }
  if a.len == 0 {
    return true;
  }
  return memcmp(a.ptr, b.ptr, a.len) == 0;
}

proc raw_len(s *byte) int {
  var len int = 0;
  while s[len] != cast(byte)0 {
    len = len + 1;
  }
  return len;
}

proc from_raw_parts(ptr *byte, len int) String {
  return String{ ptr = ptr, len = len };
}
