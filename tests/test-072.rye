/// 0
struct IntExpr {
  value int;
}

struct BoolExpr {
  value bool;
}

struct Expr {
  type int;
  data union { IntExpr, BoolExpr };
}

proc main() int {
  var data union { IntExpr, BoolExpr } = IntExpr{value = 42};
  if (cast(*IntExpr) &data).value != 42 {
    return 1;
  }
  var e = Expr{
    type = 0,
    data = IntExpr{value = 99},
  };
  if (cast(*IntExpr) &e.data).value != 99 {
    return 2;
  }
  return 0;
}
