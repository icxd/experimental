/// 0
enum Color {
  RED,
  GREEN,
  BLUE,
}

enum Offset : byte {
  A,
  B = 100,
  C,
}

proc main() int {
  var c Color = .RED;
  if c == Color.GREEN {
    return 1;
  } else if c == Color.BLUE {
    return 2;
  }
  if Color.count != 3 {
    return 3;
  }
  if Offset.count != 3 {
    return 4;
  }
  if Offset.C != 101 {
    return 5;
  }
  return 0;
}
