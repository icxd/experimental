// Runtime glue included in every compilation.
//
// Linux: libc calls `main` directly — no wrapper needed.
// macOS: `_main` receives argc/argv/envp from the loader and forwards to `main`.

extern proc main(argc int, argv **int) int;

when TARGET_OS == OS_MACOS {
  proc _main(argc int, argv **int, envp **int) int {
    var retcode int = main(argc, argv);

    return retcode;
  }
} else {
  const __rye_linux int = 0;
}
